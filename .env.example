# Tor gateway - and every included service's build-time/runtime vars in
# one place, since `docker compose up` from here starts the whole platform.
#
# Local dev: leave everything as-is. `*.localhost` resolves to 127.0.0.1
# automatically in every modern browser, no /etc/hosts editing needed.
# Caddy's automatic HTTPS upgrades all of these to https:// (with its own
# locally-trusted CA), even for plain "localhost" - so every origin below
# is https://, not http://, or the return_to allowlist will reject it:
#   https://localhost        -> schloss (home)
#   https://auth.localhost   -> schlussel (login/register)
#   https://kuvert.localhost -> kuvert
#
# Production: set DOMAIN to a real domain you control and point its DNS
# (plus auth.<domain> and kuvert.<domain>) at this host. Caddy provisions
# HTTPS automatically - no other change needed.
DOMAIN=localhost

# schlussel API - CORS allowlist. Named per-service (not plain
# ALLOWED_ORIGINS) because this file provides one shared .env for every
# included service's compose file - schlussel and kuvert-api both used to
# read a variable literally named ALLOWED_ORIGINS, so setting it here
# silently fed the same value into both and clobbered kuvert-api's own
# allowlist.
SCHLUSSEL_ALLOWED_ORIGINS=https://localhost,https://auth.localhost

# kuvert-api - CORS allowlist (see the naming note above)
KUVERT_ALLOWED_ORIGINS=https://localhost,https://kuvert.localhost

# schlussel-web - return_to origin allowlist, and where a visitor who
# opened /login or /register directly (no return_to) gets sent instead
ALLOWED_RETURN_ORIGINS=https://localhost,https://kuvert.localhost
DEFAULT_APP_URL=https://localhost

# schloss - where its Kuvert card links to, and where its "Войти" button
# and unauthenticated-visitor redirect point
KUVERT_URL=https://kuvert.localhost
SCHLUSSEL_WEB_URL=https://auth.localhost

# kuvert-web - where an unauthenticated visitor gets redirected to log in
# (kuvert-web reuses the same SCHLUSSEL_WEB_URL value as schloss above),
# and where its header's "На главную" link points back to
SCHLOSS_URL=https://localhost
