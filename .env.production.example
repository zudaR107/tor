# Production example - copy to .env and fill in your real domain.
#
# Point DNS A/AAAA records for these three hostnames at this server before
# starting the stack, so Caddy can complete the ACME HTTP-01 challenge and
# get real Let's Encrypt certificates for each of them:
#   example.com
#   auth.example.com
#   kuvert.example.com
DOMAIN=example.com

# schlussel API - CORS allowlist
ALLOWED_ORIGINS=https://example.com,https://auth.example.com

# schlussel-web - return_to origin allowlist, and where a visitor who
# opened /login or /register directly (no return_to) gets sent instead
ALLOWED_RETURN_ORIGINS=https://example.com,https://kuvert.example.com
DEFAULT_APP_URL=https://example.com

# schloss - where its Kuvert card links to, and where its "Войти" button
# and unauthenticated-visitor redirect point
KUVERT_URL=https://kuvert.example.com
SCHLUSSEL_WEB_URL=https://auth.example.com

# kuvert-web - where an unauthenticated visitor gets redirected to log in
# (kuvert-web reuses the same SCHLUSSEL_WEB_URL value as schloss above)
